# Server / secrets
DRIZZLE_DB_URL="postgresql://username:password@host:5432/database_name"
GEMINI_API_KEY="your_gemini_api_key_here"
CLERK_SECRET_KEY="sk_clerk_secret_here"
CLERK_API_URL="https://api.clerk.example"
CLERK_API_VERSION="v1"

# Public / client-readable (NEXT_PUBLIC_*)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_clerk_publishable_here"
NEXT_PUBLIC_CLERK_DOMAIN="your-clerk-domain"
NEXT_PUBLIC_CLERK_JS_VERSION=""
NEXT_PUBLIC_CLERK_JS_URL=""
NEXT_PUBLIC_CLERK_PROXY_URL=""
NEXT_PUBLIC_CLERK_IS_SATELLITE=false

NEXT_PUBLIC_INFORMATION="Short public info shown in UI"
NEXT_PUBLIC_QUESTION_NOTE="Note shown with questions"

# Optional / alternate AI providers (commented in code)
NEXT_PUBLIC_OPENAI_API_KEY="your_openai_key_here"
NEXT_PUBLIC_LLAMA_API_KEY="your_llama_key_here"

# Standard
NODE_ENV=development
